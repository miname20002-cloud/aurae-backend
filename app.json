{
  "expo": {
    "name": "aurae",
    "slug": "aurae-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B0B12",
    "scheme": "aurae",
    "icon": "./assets/images/icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aurae.app"
    },
    "android": {
      "package": "com.aurae.app",
      "backgroundColor": "#0B0B12",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0B0B12"
      }
    },
    "androidNavigationBar": {
      "enforceContrast": false
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-video",
      "expo-font",
      "./plugins/withNavBarFix.js",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-9861327921813724~6755004829",
          "iosAppId": "ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX"
        }
      ],
      "@sentry/react-native"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2cf87ada-c22e-473d-a48a-7461d5345609"
      }
    }
  }
}
